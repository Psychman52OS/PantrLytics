# PantrLytics — Standalone Docker Configuration
# Copy this file to .env and fill in your values.
# docker-compose automatically loads .env from the same directory.

# ── QR Code / Label URL ────────────────────────────────────────────────────────
# The URL encoded into QR codes on printed labels.
# Must be the address users (or barcode scanners) can actually reach.
#
# Examples:
#   http://192.168.1.100:8099       ← LAN IP + port (most common)
#   https://pantrlytics.example.com ← reverse proxy with a domain
#
# Leave blank to auto-detect from HTTP request headers (works for browser
# access but may not match what a handheld scanner expects).
BASE_URL=

# ── Label Printer (IPP/CUPS) ───────────────────────────────────────────────────
# Leave both blank if you are not printing physical labels.
# When unset, "Print Label" returns a PNG preview instead of sending to a printer.

# Hostname (or IP) and port of your CUPS/IPP server.
# Example: 192.168.1.50:631
IPP_HOST=

# IPP printer queue name as shown in CUPS.
# Example: DYMO_LabelWriter_450
IPP_PRINTER=

# ── Serial Numbers ─────────────────────────────────────────────────────────────
# Prefix prepended to every auto-generated item serial number.
# Change this to something meaningful for your setup.
SERIAL_PREFIX=ITEM-

# ── Host Port ──────────────────────────────────────────────────────────────────
# The port exposed on the host machine (docker-compose maps HOST:8099).
# Change if 8099 is already in use on your server.
PORT=8099
